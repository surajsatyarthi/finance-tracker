import type { Account, CreditCard, Loan, EMI, BNPL, Transaction, Investment } from '@/types/database'

/**
 * Calculate Net Worth using verified formula from FSD Section 11
 * Net Worth = Total Assets - Total Liabilities
 */
export function calculateNetWorth(data: {
  accounts: Account[]
  creditCards: CreditCard[]
  loans: Loan[]
  emis: EMI[]
  bnpls: BNPL[]
  investments: Investment[]
}) {
  // Assets
  const accountBalances = data.accounts
    .filter(a => !a.is_active)
    .reduce((sum, a) => sum + a.balance, 0)

  const investmentValues = data.investments
    .filter(i => !i.is_active)
    .reduce((sum, i) => sum + i.current_value, 0)

  const totalAssets = accountBalances + investmentValues

  // Liabilities
  const loanBalances = data.loans
    .filter(l => !l.is_active)
    .reduce((sum, l) => sum + l.outstanding_balance, 0)

  // Credit card balances (only credit cards, excluding debit)
  const ccBalances = data.creditCards
    .filter(cc => !cc.is_active && cc.card_type === 'credit')
    .reduce((sum, cc) => sum + cc.current_balance, 0)

  // EMI remaining amounts (NOT linked to credit cards to avoid double counting)
  const emiBalances = data.emis
    .filter(e => !e.is_active && !e.linked_card_id)
    .reduce((sum, e) => sum + e.remaining_amount, 0)

  // BNPL remaining amounts (NOT linked to credit cards to avoid double counting)
  const bnplBalances = data.bnpls
    .filter(b => !b.is_active && !b.linked_card_id)
    .reduce((sum, b) => sum + b.remaining_amount, 0)

  const totalLiabilities = loanBalances + ccBalances + emiBalances + bnplBalances

  return {
    totalAssets,
    totalLiabilities,
    netWorth: totalAssets - totalLiabilities
  }
}

/**
 * Calculate Savings Rate using verified formula from FSD Section 11
 * Savings Rate = (Monthly Income - Monthly Expenses) / Monthly Income * 100
 */
export function calculateSavingsRate(data: {
  transactions: Transaction[]
  startDate: Date
  endDate: Date
}) {
  const { transactions, startDate, endDate } = data
  const txInRange = transactions.filter(t => {
    if (t.is_active) return false
    const txDate = new Date(t.date)
    return txDate >= startDate && txDate <= endDate
  })

  const totalIncome = txInRange
    .filter(t => t.type === 'income')
    .reduce((sum, t) => sum + t.amount, 0)

  const totalExpenses = txInRange
    .filter(t => t.type === 'expense')
    .reduce((sum, t) => sum + t.amount, 0)

  if (totalIncome === 0) return 0

  return ((totalIncome - totalExpenses) / totalIncome) * 100
}

/**
 * Calculate Credit Utilization using verified formula from FSD Section 11
 * Credit Utilization = Total CC Balance / Total Credit Limit * 100
 */
export function calculateCreditUtilization(data: {
  creditCards: CreditCard[]
  emis: EMI[]
  bnpls: BNPL[]
}) {
  const activeCreditCards = data.creditCards.filter(
    cc => !cc.is_active && cc.is_active && cc.card_type === 'credit'
  )

  const totalLimit = activeCreditCards.reduce((sum, cc) => sum + (cc.credit_limit || 0), 0)

  if (totalLimit === 0) return 0

  // For each card, subtract linked EMI/BNPL amounts to avoid double counting
  let totalBalance = 0

  for (const card of activeCreditCards) {
    const linkedEMIs = data.emis.filter(e => !e.is_active && e.linked_card_id === card.id)
    const linkedBNPLs = data.bnpls.filter(b => !b.is_active && b.linked_card_id === card.id)

    const emiAmount = linkedEMIs.reduce((sum, e) => sum + e.monthly_emi, 0)
    const bnplAmount = linkedBNPLs.reduce((sum, b) => sum + b.installment_amount, 0)

    // Non-EMI balance = current balance - linked EMI/BNPL amounts
    const nonEMIBalance = card.current_balance - emiAmount - bnplAmount

    totalBalance += nonEMIBalance
  }

  return (totalBalance / totalLimit) * 100
}

/**
 * Calculate Debt Service Ratio using verified formula from FSD Section 11
 * DSR = Total Monthly Debt Payments / Monthly Income * 100
 */
export function calculateDebtServiceRatio(data: {
  loans: Loan[]
  emis: EMI[]
  bnpls: BNPL[]
  creditCards: CreditCard[]
  transactions: Transaction[]
  startDate: Date
  endDate: Date
}) {
  const { loans, emis, bnpls, transactions, startDate, endDate } = data
  const txInRange = transactions.filter(t => {
    if (t.is_active) return false
    const txDate = new Date(t.date)
    return txDate >= startDate && txDate <= endDate
  })

  const monthlyIncome = txInRange
    .filter(t => t.type === 'income')
    .reduce((sum, t) => sum + t.amount, 0)

  if (monthlyIncome === 0) return 0

  // Loan EMIs
  const loanEMIs = loans
    .filter(l => !l.is_active)
    .reduce((sum, l) => sum + l.emi_amount, 0)

  // Standalone EMIs (not linked to credit cards)
  const standaloneEMIs = emis
    .filter(e => !e.is_active && !e.linked_card_id)
    .reduce((sum, e) => sum + e.monthly_emi, 0)

  // Standalone BNPLs (not linked to credit cards)
  const standaloneBNPLs = bnpls
    .filter(b => !b.is_active && !b.linked_card_id)
    .reduce((sum, b) => sum + b.installment_amount, 0)

  const totalMonthlyDebt = loanEMIs + standaloneEMIs + standaloneBNPLs

  return (totalMonthlyDebt / monthlyIncome) * 100
}

/**
 * Calculate Liquidity Ratio using verified formula from FSD Section 11
 * Liquidity Ratio = Liquid Assets / Monthly Expenses
 */
export function calculateLiquidityRatio(data: {
  accounts: Account[]
  transactions: Transaction[]
  startDate: Date
  endDate: Date
}) {
  const { accounts, transactions, startDate, endDate } = data
  // Liquid assets = savings + current accounts (excluding FDs, investments)
  const liquidAssets = accounts
    .filter(a => !a.is_active && (a.type === 'savings' || a.type === 'current' || a.type === 'cash'))
    .reduce((sum, a) => sum + a.balance, 0)

  const txInRange = transactions.filter(t => {
    if (t.is_active) return false
    const txDate = new Date(t.date)
    return txDate >= startDate && txDate <= endDate
  })

  const monthlyExpenses = txInRange
    .filter(t => t.type === 'expense')
    .reduce((sum, t) => sum + t.amount, 0)

  if (monthlyExpenses === 0) return 0

  return liquidAssets / monthlyExpenses
}

/**
 * Get upcoming payments for the next 30 days
 * Anti-double-counting: EMI/BNPL amounts are subtracted from CC balance
 */
export function getUpcomingPayments(data: {
  creditCards: CreditCard[]
  loans: Loan[]
  emis: EMI[]
  bnpls: BNPL[]
}) {
  const today = new Date()
  const thirtyDaysLater = new Date(today)
  thirtyDaysLater.setDate(today.getDate() + 30)

  const payments: Array<{
    type: 'credit_card' | 'loan' | 'emi' | 'bnpl'
    name: string
    amount: number
    dueDate: Date
  }> = []

  // Credit card bills (with EMI/BNPL subtracted)
  for (const card of data.creditCards.filter(cc => !cc.is_active && cc.is_active && cc.due_date)) {
    const linkedEMIs = data.emis.filter(e => !e.is_active && e.linked_card_id === card.id)
    const linkedBNPLs = data.bnpls.filter(b => !b.is_active && b.linked_card_id === card.id)

    const emiAmount = linkedEMIs.reduce((sum, e) => sum + e.monthly_emi, 0)
    const bnplAmount = linkedBNPLs.reduce((sum, b) => sum + b.installment_amount, 0)

    const nonEMIBalance = card.current_balance - emiAmount - bnplAmount

    if (nonEMIBalance > 0) {
      const dueDate = new Date(today.getFullYear(), today.getMonth(), card.due_date!)
      if (dueDate <= thirtyDaysLater) {
        payments.push({
          type: 'credit_card',
          name: card.name,
          amount: nonEMIBalance,
          dueDate
        })
      }
    }
  }

  // Loan EMIs
  for (const loan of data.loans.filter(l => !l.is_active && l.emi_day)) {
    const dueDate = new Date(today.getFullYear(), today.getMonth(), loan.emi_day!)
    if (dueDate <= thirtyDaysLater) {
      payments.push({
        type: 'loan',
        name: loan.loan_name,
        amount: loan.emi_amount,
        dueDate
      })
    }
  }

  // Standalone EMIs
  for (const emi of data.emis.filter(e => !e.is_active && !e.linked_card_id)) {
    payments.push({
      type: 'emi',
      name: emi.emi_name,
      amount: emi.monthly_emi,
      dueDate: today // Simplified - would need start_date + month calculation
    })
  }

  // Standalone BNPLs
  for (const bnpl of data.bnpls.filter(b => !b.is_active && !b.linked_card_id && b.next_due_date)) {
    const dueDate = new Date(bnpl.next_due_date!)
    if (dueDate <= thirtyDaysLater) {
      payments.push({
        type: 'bnpl',
        name: bnpl.merchant,
        amount: bnpl.installment_amount,
        dueDate
      })
    }
  }

  return payments.sort((a, b) => a.dueDate.getTime() - b.dueDate.getTime())
}
