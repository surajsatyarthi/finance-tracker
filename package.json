{
  "name": "finance-tracker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "echo '✅ No unit tests yet - use test:e2e for full E2E suite' && exit 0",
    "validate:env": "npx tsx scripts/validate-env.ts",
    "validate:env:production": "npx tsx scripts/validate-env.ts --environment=production",
    "ralph:gates": "npm run build && npm run lint && npm run typecheck",
    "ralph:scan": "echo '🔍 Security scan placeholder - customize in scripts/' && exit 0",
    "prepare": "husky",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "test:setup": "node scripts/create-test-user.mjs",
    "test:e2e:chrome": "playwright test --project=chromium",
    "test:e2e:profile": "node tests/run-with-profile.mjs",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project='Mobile Chrome' --project='Mobile Safari'",
    "alpha:validate": "node ../.agent/scripts/validate-protocol.js",
    "alpha:collect": "node ../.agent/scripts/collect-evidence.js",
    "alpha:enforce": "node ../.agent/scripts/enforce-gates.js",
    "alpha:check": "npm run alpha:collect 001-LOCAL-SUPABASE && npm run alpha:validate 001-LOCAL-SUPABASE"
  },
  "dependencies": {
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.89.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.1",
    "husky": "^9.1.7",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
